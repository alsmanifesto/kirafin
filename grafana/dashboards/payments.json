{
  "title": "Payments API – DORA & Operational Metrics",
  "uid": "payments-api-v1",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Transfers",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(transfer_requests_total)", "legendFormat": "Total"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success Rate",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(transfer_requests_total{status='success'}) / sum(transfer_requests_total) * 100",
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests per Vendor (rate 1m)",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "rate(transfer_requests_total[1m])",
          "legendFormat": "{{vendor}} – {{status}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "P99 Latency per Vendor",
      "gridPos": {"x": 0, "y": 10, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(transfer_latency_seconds_bucket[5m]))",
          "legendFormat": "p99 {{vendor}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Txhash Confirmation Results",
      "gridPos": {"x": 0, "y": 16, "w": 6, "h": 6},
      "targets": [
        {
          "expr": "txhash_confirmations_total",
          "legendFormat": "{{result}}"
        }
      ]
    }
  ]
}
